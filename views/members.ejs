<%- include('templates/header') %>

<h1 class="mt-5">Welcome to the members area, <%= username %>!</h1>

<div class="container d-flex flex-column align-items-center justify-content-center">
  <div class="row row-cols-1 row-cols-md-3 g-4 w-100 justify-content-center">
    
    <% cats.forEach(cat => { %>
      <div class="col d-flex justify-content-center">
          <div class="card shadow-sm">
            <img class="img-fluid rounded" src="<%= cat %>" alt="Cat" style="object-fit: cover; height: 250px; width: 100%;">
          </div>
      </div>
    <% }); %>

  </div>
</div>
<a href="/logout"><button type="button" class="btn btn-danger my-2" data-mdb-ripple-init>Logout</button></a>

<%- include('templates/footer') %>
